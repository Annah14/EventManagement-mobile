<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <ImageView
        android:id="@+id/ivBookingBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.4"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Your Event"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reserve your luxury experience"
                android:textColor="@color/brand_gold"
                android:textSize="14sp"
                android:layout_marginBottom="32dp"/>

            <!-- Form -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Package Type"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />
                <Spinner
                    android:id="@+id/spinnerPackage"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Event Type"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etEventType"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="e.g. Wedding, Birthday"
                    android:textColorHint="#88000000"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Event Date"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etEventDate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="YYYY-MM-DD"
                    android:textColorHint="#88000000"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"
                    android:focusable="false"
                    android:clickable="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Venue Location"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etVenue"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Venue Address"
                    android:textColorHint="#88000000"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated Guests"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etGuests"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Number of guests"
                    android:inputType="number"
                    android:textColorHint="#88000000"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Method"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <Spinner
                    android:id="@+id/spinnerPayment"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input"
                    android:paddingHorizontal="12dp" />

                <!-- Payment Details Container -->
                <LinearLayout
                    android:id="@+id/llPaymentDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvPaymentDetailLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp" />
                    <EditText
                        android:id="@+id/etPaymentDetail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="Number"
                        android:inputType="phone"
                        android:textColorHint="#88000000"
                        android:textColor="@android:color/black"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvPaymentPinLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transaction PIN"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="8dp" />
                    <EditText
                        android:id="@+id/etPaymentPin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="PIN"
                        android:inputType="numberPassword"
                        android:textColorHint="#88000000"
                        android:textColor="@android:color/black"
                        android:background="@drawable/bg_input"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Additional Details"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp" />
                <EditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="top"
                    android:hint="Requests..."
                    android:textColorHint="#88000000"
                    android:textColor="@android:color/black"
                    android:background="@drawable/bg_input"
                    android:padding="16dp"
                    android:textSize="14sp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitBooking"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="48dp"
                    android:text="Submit Booking"
                    app:backgroundTint="@color/brand_gold"
                    app:cornerRadius="30dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>