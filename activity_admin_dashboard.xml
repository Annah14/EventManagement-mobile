<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivAdminBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="0.2"/>

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarAdmin"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:navigationIcon="@drawable/ic_menu"
            app:title="Admin Panel"
            app:titleTextColor="@color/white" />

        <FrameLayout
            android:id="@+id/adminContentFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/toolbarAdmin"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Default View: Bookings (Main Dashboard) -->
            <ScrollView
                android:id="@+id/scrollBookings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Booking Requests"
                        android:textColor="@color/brand_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:id="@+id/adminBookingsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </ScrollView>

            <!-- Services Section -->
            <ScrollView
                android:id="@+id/scrollServices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Services"
                        android:textColor="@color/brand_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <!-- Form -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#1AFFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="vertical">
                            <EditText android:id="@+id/etAdminServiceTitle" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Title" android:background="@drawable/bg_input" android:paddingHorizontal="12dp" />
                            <EditText android:id="@+id/etAdminServiceShort" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:hint="Tagline" android:background="@drawable/bg_input" android:paddingHorizontal="12dp" />
                            <Button android:id="@+id/btnAddServiceAdmin" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Add Service" android:backgroundTint="@color/brand_gold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:id="@+id/adminServicesListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" />
                </LinearLayout>
            </ScrollView>

            <!-- Packages Section -->
            <ScrollView
                android:id="@+id/scrollPackages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Packages"
                        android:textColor="@color/brand_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="#1AFFFFFF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:orientation="vertical">
                            <EditText android:id="@+id/etAdminPkgName" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Package Name" android:background="@drawable/bg_input" android:paddingHorizontal="12dp" />
                            <EditText android:id="@+id/etAdminPkgPrice" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:hint="Price" android:inputType="numberDecimal" android:background="@drawable/bg_input" android:paddingHorizontal="12dp" />
                            <EditText android:id="@+id/etAdminPkgShort" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:hint="Summary" android:background="@drawable/bg_input" android:paddingHorizontal="12dp" />
                            <Button android:id="@+id/btnLaunchPkgAdmin" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Launch Package" android:backgroundTint="@color/brand_gold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <LinearLayout android:id="@+id/adminPackagesListContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="16dp" />
                </LinearLayout>
            </ScrollView>

            <!-- Inquiries Section -->
            <ScrollView
                android:id="@+id/scrollInquiries"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Inquiries"
                        android:textColor="@color/brand_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:id="@+id/adminInquiriesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </ScrollView>

        </FrameLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_admin"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#111"
        app:itemTextColor="@color/white"
        app:itemIconTint="@color/brand_gold"
        app:menu="@menu/admin_drawer_menu"
        app:headerLayout="@layout/nav_header_admin" />

</androidx.drawerlayout.widget.DrawerLayout>
